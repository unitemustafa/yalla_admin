generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model DashboardItem {
  id          String   @id
  code        String   @unique
  position    Int
  image       String
  name        String
  description String
  category    String
  subcategory String
  calories    String
  // TODO: Convert demo price strings to typed numeric currency fields in a planned migration.
  price       String
  variantDetails String @default("{}")
  visibilityMode String @default("general")
  regionSlugs String @default("[]")
  regionNames String @default("[]")
  featured    String
  active      Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dashboard_items")
}

model DashboardOrder {
  number    String   @id
  position  Int
  customer  String
  phone     String
  type      String
  status    String
  total     Float
  // TODO: Convert demo date/time strings to typed date fields in a planned migration.
  date      String
  time      String
  payment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dashboard_orders")
}
