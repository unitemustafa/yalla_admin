# Django API base URL. This public value is embedded during `next build`.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1

# Backend origin used to resolve relative /media/ paths.
NEXT_PUBLIC_BACKEND_URL=https://api.example.com

# Optional dedicated media origin. Remove this line when media is served by
# NEXT_PUBLIC_BACKEND_URL.
NEXT_PUBLIC_MEDIA_BASE_URL=https://api.example.com
